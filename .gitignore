# Secrets — 키 노출 방지 (절대 git 에 올리지 말 것)
.env
keys_local.txt
*_secrets.txt

# OAuth 토큰 캐시 (재발급되니 굳이 옮길 필요 없음)
data/cache_*_token.json

# Claude Code 인스턴스 상태 (PC 별)
.claude/

# Virtual envs
.venv/
venv/
env/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
build/
dist/

# 대용량 / 재생성 가능 — git 에 안 올림
data/cache_*.json
!data/cache_manifest.json
data/cache.db
data/cache.db-wal
data/cache.db-shm
data/icons/
data/_json_backup/
data/spell_db_en.json

# v2_cache_*.json 은 Git LFS 로 트래킹 (PC 간 sync 가능) — .gitattributes 참고

# PC 별 사용자 설정 (테마 등) — sync 안 함
data/user_settings.json
data/backfill.log
# data/user_characters.json 은 git 으로 sync (사용자 요청)

# 인증 — 사용자 DB + secret 키 (per-PC, 절대 push 금지)
data/users.db
data/users.db-wal
data/users.db-shm
data/auth_secret

# 로그 — serve.py 가 .exe 옆 또는 project root logs/ 에 시간별 .log 떨굼
*.log
logs/

# PyInstaller spec
*.spec

# IDE / OS
.idea/
.vscode/
.DS_Store
Thumbs.db

