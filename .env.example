# =============================================================================
# WoWAnalyzer 시크릿 — .env 파일로 복사 (cp .env.example .env) 후 채우기
# =============================================================================
#
# ⚠️  .env 파일은 .gitignore 로 git 푸시 안 됨.
#     새 PC 셋업 시: 이 파일을 .env 로 복사하고 5개 키 채워넣음.
#     (또는 기존 PC 의 .env 그대로 복사 — 다른 PC 에서 같은 키 재사용 OK)
#
# =============================================================================
#
# (1) WarcraftLogs V1 API Key  — 일부 legacy enrich 호환
#     발급: https://www.warcraftlogs.com/profile   →  Web API 섹션
#
WCL_V1_KEY=
#
# =============================================================================
#
# (2/3) WarcraftLogs V2 (GraphQL) — 메인 데이터 페치
#     발급: https://www.warcraftlogs.com/api/clients
#       - Client name: 아무 (예: "wow-analyzer")
#       - Redirect URLs: http://localhost
#       - Public Client: ☐ unchecked
#     Create 후 client_id + client_secret 둘 다 복사 (secret 은 한 번만 표시)
#
#     Platinum 구독 ($10/월) 시 시간당 18,000 포인트 (기본 free 3,600).
#     리미트는 https://www.warcraftlogs.com/api/clients 에서 변경 가능.
#
WCL_V2_CLIENT_ID=
WCL_V2_CLIENT_SECRET=
#
# =============================================================================
#
# (4/5) Blizzard Battle.net Game Data API — 권위 있는 한글 spell/talent/boss 이름
#     발급: https://develop.battle.net/access/clients
#       - Client Name: 아무 (예: "wow-loganalyze-kr")
#       - Redirect URLs: http://localhost
#       - "I do not have a service URL for this client" ☑ 체크
#       - Intended Use: "Personal log analyzer. Fetches localized (ko_KR) game data."
#     Save 후 Client ID + Secret 둘 다 표시됨 (페이지 떠나도 다시 볼 수 있음).
#
#     무료, rate limit 36,000 req/hr.
#
BLIZZARD_CLIENT_ID=
BLIZZARD_CLIENT_SECRET=
#
# =============================================================================
